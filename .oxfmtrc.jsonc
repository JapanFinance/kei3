{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "semi": true,
  "printWidth": 100,
  "tabWidth": 2,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "sortPackageJson": true,
  "sortImports": true,
  "ignorePatterns": [
    "dist",
    "node_modules",
    ".claude",
    ".wrangler",
    "package-lock.json",
    // Markdown is left to authors (the changelog is parsed with a specific structure).
    "*.md",
  ],
}
